{
  "name": "ai-prof-chai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5178",
    "dev:server": "tsx watch server/index.ts",
    "start": "NODE_ENV=production tsx server/index.ts",
    "build": "tsc --noEmit && vite build",
    "build:worker-knowledge": "tsx scripts/build-worker-knowledge.ts",
    "build:pages": "npm run build:worker-knowledge && vite build --base ./ --outDir docs --emptyOutDir false",
    "deploy:worker": "npm run build:worker-knowledge && npx wrangler deploy",
    "test": "vitest run",
    "import:wos": "tsx scripts/import-wos.ts",
    "ingest:pdfs": "tsx scripts/ingest-manual-pdfs.ts",
    "ingest:downloads": "tsx scripts/ingest-manual-pdfs.ts --downloads",
    "watch:pdfs": "tsx scripts/watch-pdf-downloads.ts",
    "refresh:pdfs": "tsx scripts/refresh-after-downloads.ts",
    "sync:desktop": "tsx scripts/sync-desktop-project.ts",
    "index:pdfs": "tsx scripts/index-pdf-fulltext.ts",
    "audit:pdfs": "tsx scripts/audit-saved-pdfs.ts",
    "distill": "tsx scripts/generate-distillation.ts",
    "export:targets": "tsx scripts/export-targets.ts",
    "export:missing-pdfs": "tsx scripts/export-missing-pdfs.ts",
    "export:download-pack": "tsx scripts/export-download-pack.ts",
    "export:sprint": "tsx scripts/export-sprint-checklist.ts",
    "export:browser-shortcuts": "tsx scripts/export-browser-shortcuts.ts",
    "export:library-request": "tsx scripts/export-library-request-pack.ts",
    "export:acquisition-pack": "tsx scripts/export-acquisition-pack.ts",
    "export:coverage": "tsx scripts/export-target-coverage-matrix.ts",
    "export:evidence-pack": "tsx scripts/export-evidence-pack.ts",
    "eval:assistant": "tsx scripts/evaluate-assistant.ts",
    "report:status": "tsx scripts/generate-project-status.ts",
    "audit:goal": "tsx scripts/generate-goal-audit.ts",
    "setup:ai": "tsx scripts/configure-ai-token.ts",
    "check:ai": "tsx scripts/check-ai-connection.ts",
    "fetch:openalex": "tsx scripts/fetch-openalex-seed.ts",
    "download:wos-oa": "tsx scripts/download-wos-openalex-oa.ts",
    "download:openalex-oa": "tsx scripts/download-openalex-oa.ts",
    "check:missing-oa": "tsx scripts/check-missing-open-access.ts",
    "check:missing-metadata": "tsx scripts/check-missing-scholarly-metadata.ts",
    "check:cuhk-pure": "tsx scripts/check-cuhk-pure-pdfs.ts",
    "download:missing-direct": "tsx scripts/download-missing-direct-routes.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22"
  }
}
