AI_PROF_CHAI_AI_PROVIDER=deepseek
AI_PROF_CHAI_DEEPSEEK_API_KEY=
# You can also set DEEPSEEK_API_KEY or DEEPSEEK_API_TOKENS in your shell instead.
AI_PROF_CHAI_DEEPSEEK_MODEL=deepseek-v4-flash
AI_PROF_CHAI_DEEPSEEK_API_BASE=https://api.deepseek.com
AI_PROF_CHAI_DAILY_LIMIT=50
AI_PROF_CHAI_MAX_TOKENS=800
AI_PROF_CHAI_MIN_BALANCE_USD=0.20
AI_PROF_CHAI_MIN_BALANCE_CNY=1

# Optional DashScope alternative
AI_PROF_CHAI_DASHSCOPE_API_KEY=
AI_PROF_CHAI_DASHSCOPE_MODEL=qwen-plus
AI_PROF_CHAI_DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
